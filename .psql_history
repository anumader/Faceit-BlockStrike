CREATE TABLE matches (    id SERIAL PRIMARY KEY,    status TEXT DEFAULT 'veto', -- статус: veto, ready, finished    banned_maps TEXT[] DEFAULT '{}', -- массив строк со списком забаненных карт    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);-- Создаем тестовый матчINSERT INTO matches (status) VALUES ('veto');-- Выходим из консоли (напиши \q и нажми Enter)\q
-- Таблица игроковCREATE TABLE users (    id SERIAL PRIMARY KEY,    nickname TEXT UNIQUE,    elo INTEGER,    avatar_url TEXT);-- Добавим тебя и еще 9 ботов для тестаINSERT INTO users (nickname, elo) VALUES ('Nutcracker', 2105),('S1mple', 2100),('ZywOo', 2050),('Donk', 2000),('m0NESY', 1950),('NiKo', 1900),('sh1ro', 1850),('dev1ce', 1800),('ropz', 1750),('b1t', 1700);-- Добавим в таблицу матчей колонки для капитановALTER TABLE matches ADD COLUMN cap_a_id INTEGER REFERENCES users(id);ALTER TABLE matches ADD COLUMN cap_b_id INTEGER REFERENCES users(id);ALTER TABLE matches ADD COLUMN current_turn_id INTEGER REFERENCES users(id);
-- Добавляем статус готовности и время входа в поискALTER TABLE users ADD COLUMN is_ready BOOLEAN DEFAULT FALSE;ALTER TABLE users ADD COLUMN in_search BOOLEAN DEFAULT FALSE;-- Сбрасываем всех в "не готов"UPDATE users SET is_ready = false, in_search = false;
\q
-- Убедимся, что матч ID=1 имеет правильных капитанов и сейчас ход Капитана А (ID=1)UPDATE matches SET     cap_a_id = 1,     cap_b_id = 2,     current_turn_id = 1,     turn_count = 3,     banned_maps = '{}' WHERE id = 1;
-- Добавляем колонку turn_count, если её нетALTER TABLE matches ADD COLUMN turn_count INTEGER DEFAULT 3;-- Теперь повторяем тот самый UPDATE, который выдавал ошибкуUPDATE matches SET     cap_a_id = 1,     cap_b_id = 2,     current_turn_id = 1,     turn_count = 3,     banned_maps = '{}' WHERE id = 1;-- Проверяем на всякий случай, какие ID у нас в таблице usersSELECT id, nickname FROM users;
\q
